<!-- wepppy/weppcloud/templates/js/run_page_bootstrap.js.j2 -->
<script>
"use strict";

(function () {
    {% set mods_list = ron.mods or [] %}
    {% set openet_admin_enabled = openet_admin_enabled if openet_admin_enabled is defined else playwright_load_all %}
    {% set allow_debris_flow = allow_debris_flow if allow_debris_flow is defined else playwright_load_all %}
    {% if ron.boundary %}
    {% set boundary = {
        "url": site_prefix ~ "/" ~ ron.boundary,
        "layerName": ron.boundary_name,
        "style": {
            "color": ron.boundary_color,
            "opacity": 1,
            "weight": 1,
            "fillOpacity": 0.0
        }
    } %}
    {% else %}
    {% set boundary = None %}
    {% endif %}

    {% set rangeland_has_covers = False %}
    {% if 'rangeland_cover' in mods_list %}
        {% set rangeland_has_covers = rangeland_cover.has_covers %}
    {% endif %}

    {% if omni_has_ran_scenarios is not defined %}
        {% set omni_has_ran_scenarios = False %}
        {% if 'omni' in mods_list and omni %}
            {% set omni_has_ran_scenarios = omni.has_ran_scenarios %}
        {% endif %}
    {% endif %}
    {% if omni_has_ran_contrasts is not defined %}
        {% set omni_has_ran_contrasts = False %}
        {% if 'omni' in mods_list and omni %}
            {% set omni_has_ran_contrasts = omni.has_ran_contrasts %}
        {% endif %}
    {% endif %}

    {% set rhem_has_run = False %}
    {% if 'rhem' in mods_list %}
        {% set rhem_has_run = rhem.has_run %}
    {% endif %}

    {% set ash_enabled = show_ash if show_ash is defined else ((('ash' in mods_list) and (ash is defined) and (ash is not none)) or playwright_load_all) %}
    {% set show_omni = show_omni if show_omni is defined else ('omni' in mods_list or playwright_load_all) %}
    {% set show_roads = show_roads if show_roads is defined else ('roads' in mods_list or playwright_load_all) %}
    {% set show_geneva = show_geneva if show_geneva is defined else ('geneva' in mods_list or playwright_load_all) %}
    {% set show_features_export = show_features_export if show_features_export is defined else ('features_export' in mods_list or playwright_load_all) %}
    {% set show_dss_export = show_dss_export if show_dss_export is defined else ('dss_export' in mods_list or playwright_load_all) %}
    {% set show_path_ce = show_path_ce if show_path_ce is defined else ('path_ce' in mods_list or playwright_load_all) %}
    {% set show_rap_ts = show_rap_ts if show_rap_ts is defined else ('rap_ts' in mods_list or playwright_load_all) %}
    {% set show_treatments = show_treatments if show_treatments is defined else ('treatments' in mods_list or playwright_load_all) %}
    {% set show_observed = show_observed if show_observed is defined else ('observed' in mods_list or playwright_load_all) %}
    {% set show_ag_fields = show_ag_fields if show_ag_fields is defined else ('ag_fields' in mods_list or playwright_load_all) %}
    {% set show_debris_flow = show_debris_flow if show_debris_flow is defined else ((('debris_flow' in mods_list) and allow_debris_flow) or playwright_load_all) %}
    {% set ash_has_results = False %}
    {% set ash_depth_mode = None %}
    {% if ash_enabled and ash is defined and ash is not none %}
        {% set ash_has_results = ash.has_ash_results %}
        {% set ash_depth_mode = ash.ash_depth_mode %}
    {% endif %}

{% set climate_precip_mode = climate.precip_scaling_mode if climate.precip_scaling_mode is defined else None %}
{% set disturbed_mode = disturbed.sbs_mode if disturbed is not none else 0 %}
{% set disturbed_uniform = disturbed.uniform_severity if disturbed is not none else None %}
{% set baer_mode = baer.sbs_mode if baer is not none else disturbed_mode %}
{% set baer_uniform = baer.uniform_severity if baer is not none else disturbed_uniform %}
{% set hide_landuse_wepp = 'rhem' in mods_list %}
{% set rusle_backend_supported = rusle_backend_supported if rusle_backend_supported is defined else (watershed.delineation_backend_is_wbt if watershed is defined and watershed is not none and watershed.delineation_backend_is_wbt is defined else False) %}
{% set show_rusle = show_rusle if show_rusle is defined else ((('rusle' in mods_list) and ('disturbed' in mods_list) and rusle_backend_supported) or playwright_load_all) %}
{% set ttl_state = current_ttl if current_ttl is defined else None %}

    var sitePrefix = {{ site_prefix | tojson }};
    var runId = {{ ron.runid | tojson }};
    var runConfig = {{ ron.config_stem | tojson }};

    var runContext = {{ {
        "run": {
            "id": ron.runid,
            "config": ron.config_stem,
            "sitePrefix": site_prefix
        },
        "user": {
            "isPowerUser": current_user.has_role('PowerUser'),
            "isAdmin": current_user.has_role('Admin') or current_user.has_role('Root'),
            "isRoot": current_user.has_role('Root'),
            "isAuthenticated": user.is_authenticated,
            "readonly": ron.readonly
        },
        "ttl": {
            "policy": ((ttl_state.policy | default(None)) if ttl_state else None),
            "userDisabled": ((ttl_state.user_disabled | default(False)) if ttl_state else False),
            "disabledReason": ((ttl_state.disabled_reason | default(None)) if ttl_state else None),
            "expiresAt": ((ttl_state.expires_at | default(None)) if ttl_state else None)
        },
        "environment": {
            "cellSize": ron.cellsize
        },
        "jobIds": rq_job_ids,
        "mods": {
            "list": mods_list,
            "flags": {
                "baer": 'baer' in mods_list,
                "disturbed": 'disturbed' in mods_list,
                "rangeland_cover": 'rangeland_cover' in mods_list,
                "ash": ash_enabled,
                "omni": show_omni,
                "rhem": 'rhem' in mods_list,
                "dss_export": show_dss_export,
                "path_ce": show_path_ce,
                "debris_flow": show_debris_flow,
                "roads": show_roads,
                "geneva": show_geneva,
                "features_export": show_features_export,
                "rap_ts": show_rap_ts,
                "openet_ts": ('openet_ts' in mods_list) and openet_admin_enabled,
                "treatments": show_treatments,
                "observed": show_observed,
                "ag_fields": show_ag_fields,
                "rusle": show_rusle
            }
        },
        "flags": {
            "initialHasSbs": ron.has_sbs,
            "hasDem": ron.has_dem,
            "playwrightLoadAll": playwright_load_all
        },
        "map": {
            "center": ron.center0,
            "zoom": ron.zoom0,
            "boundary": boundary
        },
        "data": {
            "watershed": {
                "hasChannels": watershed.has_channels,
                "hasSubcatchments": watershed.has_subcatchments,
                "hasOutlet": watershed.has_outlet
            },
            "landuse": {
                "hasLanduse": landuse.has_landuse,
                "mode": landuse.mode,
                "singleSelection": landuse.single_selection
            },
            "soils": {
                "hasSoils": soils.has_soils,
                "mode": soils.mode,
                "singleDbSelection": soils.single_dbselection
            },
            "climate": {
                "hasStation": climate.has_station,
                "hasClimate": climate.has_climate,
                "hasObserved": climate.has_observed,
                "precipScalingMode": climate_precip_mode
            },
            "observed": {
                "hasResults": observed.results is not none
            },
            "rangelandCover": {
                "hasCovers": rangeland_has_covers
            },
            "wepp": {
                "hasRun": wepp.has_run,
                "dssExportMode": wepp.dss_export_mode,
                "hasDssZip": wepp.has_dss_zip
            },
            "bootstrap": {
                "enabled": wepp.bootstrap_enabled,
                "adminDisabled": bootstrap_admin_disabled,
                "isAnonymous": bootstrap_is_anonymous
            },
            "omni": {
                "hasRanScenarios": omni_has_ran_scenarios,
                "hasRanContrasts": omni_has_ran_contrasts
            },
            "rhem": {
                "hasRun": rhem_has_run
            },
            "ash": {
                "hasResults": ash_has_results,
                "depthMode": ash_depth_mode
            }
        },
        "controllers": {
            "map": {"boundary": boundary},
            "channel": {"zoomMin": 11},
            "subcatchment": {"defaultColorMap": "slp_asp"},
            "project": {"readonly": ron.readonly},
            "wepp": {"job_id": wepp.job_id, "job_key": wepp.job_key},
            "outlet": {},
            "disturbed": {"mode": disturbed_mode, "uniformSeverity": disturbed_uniform},
            "baer": {"mode": baer_mode, "uniformSeverity": baer_uniform},
            "omni": {"hasRanScenarios": omni_has_ran_scenarios, "hasRanContrasts": omni_has_ran_contrasts},
            "geneva": {"stateAuthority": "rq_engine"}
        },
        "ui": {
            "tocTaskEmojis": toc_task_emojis,
            "disabledControllers": disabled_controllers
        }
    } | tojson }};

    var modsFlags = runContext.mods && runContext.mods.flags ? runContext.mods.flags : {};
    if (runContext.flags && runContext.flags.playwrightLoadAll && modsFlags) {
        [
            "baer",
            "disturbed",
            "rangeland_cover",
            "omni",
            "rhem",
            "ash",
            "path_ce",
            "debris_flow",
            "roads",
            "geneva",
            "features_export",
            "openet_ts",
            "dss_export",
            "rusle"
        ].forEach(function (modName) {
            modsFlags[modName] = true;
        });
    }

    window.site_prefix = sitePrefix;
    window.runid = runId;
    window.runId = runId;
    window.config = runConfig;
    window.readonly = {{ ron.readonly | tojson }};
    window.WEPP_channel_critical_shear = null;
    window.runContext = runContext;

    function initUnitizers() {
        if (typeof initUnitConverters === "function") {
            try {
                initUnitConverters(document);
            } catch (err) {
                console.warn("[Bootstrap] Unitizer initialization failed", err);
            }
        }
    }

    function createBootstrapEntries(context) {
        var modFlags = context.mods && context.mods.flags ? Object.assign({}, context.mods.flags) : {};
        if (context.flags && context.flags.playwrightLoadAll) {
            modFlags.baer = true;
            modFlags.disturbed = true;
            modFlags.rangeland_cover = true;
            modFlags.omni = true;
            modFlags.rhem = true;
            modFlags.ash = true;
            modFlags.path_ce = true;
            modFlags.debris_flow = true;
            modFlags.roads = true;
            modFlags.geneva = true;
            modFlags.features_export = true;
            modFlags.openet_ts = true;
            modFlags.treatments = true;
            modFlags.rusle = true;
            modFlags.ag_fields = true;
        }
        var disabledControllers = new Set(
            (context.ui && Array.isArray(context.ui.disabledControllers)) ? context.ui.disabledControllers : []
        );
        var entries = [];

        function add(name, symbol) {
            if (disabledControllers.has(name)) {
                return;
            }
            if (!symbol || typeof symbol.getInstance !== "function") {
                return;
            }
            entries.push({ controller: symbol, name: name });
        }

        add("project", typeof Project !== "undefined" ? Project : null);
        add("team", typeof Team !== "undefined" ? Team : null);
        add("map", typeof MapController !== "undefined" ? MapController : null);
        add("channel", typeof ChannelDelineation !== "undefined" ? ChannelDelineation : null);
        add("outlet", typeof Outlet !== "undefined" ? Outlet : null);
        add("subcatchment", typeof SubcatchmentDelineation !== "undefined" ? SubcatchmentDelineation : null);
        add("landuse", typeof Landuse !== "undefined" ? Landuse : null);
        add("landuseModify", typeof LanduseModify !== "undefined" ? LanduseModify : null);
        add("soil", typeof Soil !== "undefined" ? Soil : null);
        add("climate", typeof Climate !== "undefined" ? Climate : null);
        add("observed", typeof Observed !== "undefined" ? Observed : null);
        if (modFlags.ag_fields) {
            add("agFields", typeof AgFields !== "undefined" ? AgFields : null);
        }
        add("wepp", typeof Wepp !== "undefined" ? Wepp : null);
        add("bootstrap", typeof BootstrapControl !== "undefined" ? BootstrapControl : null);
        add("dssExport", typeof DssExport !== "undefined" ? DssExport : null);
        if (modFlags.treatments) {
            add("treatments", typeof Treatments !== "undefined" ? Treatments : null);
        }
        if (modFlags.debris_flow) {
            add("debrisFlow", typeof DebrisFlow !== "undefined" ? DebrisFlow : null);
        }
        if (modFlags.roads) {
            add("roads", typeof Roads !== "undefined" ? Roads : null);
            add("roadsMapOverlay", typeof RoadsMapOverlay !== "undefined" ? RoadsMapOverlay : null);
        }
        if (modFlags.features_export) {
            add("featuresExport", typeof FeaturesExport !== "undefined" ? FeaturesExport : null);
        }
        add("rapTs", typeof RAP_TS !== "undefined" ? RAP_TS : null);
        if (modFlags.openet_ts) {
            add("openetTs", typeof OPENET_TS !== "undefined" ? OPENET_TS : null);
        }

        if (modFlags.disturbed || modFlags.baer) {
            add("disturbed", typeof Disturbed !== "undefined" ? Disturbed : null);
        }
        if (modFlags.baer) {
            add("baer", typeof Baer !== "undefined" ? Baer : null);
        }
        if (modFlags.rangeland_cover) {
            add("rangelandCover", typeof RangelandCover !== "undefined" ? RangelandCover : null);
            add("rangelandCoverModify", typeof RangelandCoverModify !== "undefined" ? RangelandCoverModify : null);
        }
        if (modFlags.omni) {
            add("omni", typeof Omni !== "undefined" ? Omni : null);
            add("omniContrastOverlays", typeof OmniContrastOverlays !== "undefined" ? OmniContrastOverlays : null);
        }
        if (modFlags.rhem) {
            add("rhem", typeof Rhem !== "undefined" ? Rhem : null);
        }
        if (modFlags.geneva) {
            add("geneva", typeof Geneva !== "undefined" ? Geneva : null);
        }
        if (modFlags.ash) {
            add("ash", typeof Ash !== "undefined" ? Ash : null);
        }
        if (modFlags.path_ce && typeof PathCE !== "undefined" && PathCE && typeof PathCE.getInstance === "function") {
            add("pathCe", PathCE);
        }
        if (modFlags.rusle) {
            add("rusle", typeof Rusle !== "undefined" ? Rusle : null);
        }

        return entries;
    }

    var MAX_BOOTSTRAP_STACK_LINES = 80;
    var MAX_BOOTSTRAP_RECORDER_EVENTS = 8;
    var MAX_BOOTSTRAP_FALLBACK_ERROR_KEYS = 256;
    var bootstrapNotifier = null;
    var bootstrapFallbackErrorKeys = {};
    var bootstrapFallbackErrorKeyOrder = [];

    function resolveBootstrapNotifier() {
        if (bootstrapNotifier && typeof bootstrapNotifier.notify === "function") {
            return bootstrapNotifier;
        }
        var helper = window.WCBootstrapObservability || null;
        if (!helper || typeof helper.createBootstrapErrorNotifier !== "function") {
            return null;
        }
        bootstrapNotifier = helper.createBootstrapErrorNotifier({
            maxStackLines: MAX_BOOTSTRAP_STACK_LINES,
            maxRecorderEvents: MAX_BOOTSTRAP_RECORDER_EVENTS,
            commandBarFactory: function () {
                if (typeof window.initializeCommandBar !== "function") {
                    return null;
                }
                return window.initializeCommandBar();
            },
            recorderFactory: function () {
                return window.WCRecorder || null;
            },
            logger: window.console || null
        });
        return bootstrapNotifier;
    }

    function sanitizeBootstrapFallbackLine(line) {
        var text = String(line === undefined || line === null ? "" : line);
        text = text.replace(/\bauthorization\b\s*:\s*[^\r\n]*/gi, "authorization: [redacted]");
        text = text.replace(/\bauthorization\b\s*=\s*[^\r\n]*/gi, "authorization=[redacted]");
        text = text.replace(/\b(set-cookie|cookie)\b\s*:\s*[^\r\n]*/gi, "$1: [redacted]");
        text = text.replace(/\b(set-cookie|cookie)\b\s*=\s*[^\r\n]*/gi, "$1=[redacted]");
        text = text.replace(/\b(x-api-key|api-key|x-auth-token|x-csrf-token)\b\s*:\s*[^\r\n]*/gi, "$1: [redacted]");
        text = text.replace(/\b(x-api-key|api-key|x-auth-token|x-csrf-token)\b\s*=\s*[^\r\n]*/gi, "$1=[redacted]");
        text = text.replace(/\bauthorization\b\s+(?:Bearer|Token)\s+[^\s,;]+/gi, "authorization [redacted]");
        text = text.replace(/\b(Bearer|Token)\s+[A-Za-z0-9._~+\/-]+=*/gi, "$1 [redacted]");
        text = text.replace(
            /([?&](?:token|access_token|refresh_token|id_token|key|api_key|apikey|api-key|x-api-key|authorization|set-cookie|cookie|session|email|auth|x-auth-token|x-csrf-token)=)([^&\s#]+)/gi,
            "$1[redacted]"
        );
        text = text.replace(
            /\b(token|access_token|refresh_token|id_token|key|api_key|apikey|api-key|x-api-key|authorization|set-cookie|cookie|session|email|auth|x-auth-token|x-csrf-token)\b\s*=\s*([^\s,;&]+)/gi,
            "$1=[redacted]"
        );
        text = text.replace(
            /((?:\\[\\"'])?(?:token|access_token|refresh_token|id_token|key|api_key|apikey|api-key|x-api-key|authorization|set-cookie|cookie|session|email|auth|x-auth-token|x-csrf-token)(?:\\[\\"'])?\s*:\s*(?:\\[\\"']))([^\\]*?)((?:\\[\\"']))/gi,
            "$1[redacted]$3"
        );
        text = text.replace(
            /((?:\\?[\\"'])?(?:token|access_token|refresh_token|id_token|key|api_key|apikey|api-key|x-api-key|authorization|set-cookie|cookie|session|email|auth|x-auth-token|x-csrf-token)(?:\\?[\\"'])?\s*:\s*(?:\\?[\\"']))([^"\\]*?)((?:\\?[\\"']))/gi,
            "$1[redacted]$3"
        );
        text = text.replace(/[A-Z0-9._%+-]+@[A-Z0-9.-]+\.[A-Z]{2,}/gi, "[redacted-email]");
        return text;
    }

    function resolveBootstrapFallbackMessage(err) {
        if (err === undefined || err === null) {
            return "";
        }
        if (typeof err === "string") {
            return err;
        }
        if (typeof err === "object") {
            if (typeof err.message === "string" && err.message) {
                return err.message;
            }
            if (typeof err.detail === "string" && err.detail) {
                return err.detail;
            }
        }
        return String(err);
    }

    function resolveBootstrapFallbackStack(err) {
        var raw = "";
        if (err && err.stack) {
            raw = err.stack;
        } else if (err && err.detail) {
            raw = err.detail;
        } else {
            raw = resolveBootstrapFallbackMessage(err);
        }
        if (!raw) {
            return [];
        }
        var lines = String(raw).split(/\r?\n/).filter(function (line) {
            return line !== "";
        });
        if (lines.length > MAX_BOOTSTRAP_STACK_LINES) {
            lines = lines.slice(0, MAX_BOOTSTRAP_STACK_LINES);
            lines.push("... [truncated]");
        }
        return lines.map(function (line) {
            return sanitizeBootstrapFallbackLine(line);
        });
    }

    function notifyBootstrapError(summary, err, meta) {
        var notifier = resolveBootstrapNotifier();
        if (notifier && typeof notifier.notify === "function") {
            notifier.notify(summary, err, meta);
            return;
        }

        var fallbackMessage = resolveBootstrapFallbackMessage(err);

        var fallbackKey = [
            summary || "",
            meta && meta.stage ? meta.stage : "",
            meta && meta.controller ? meta.controller : "",
            fallbackMessage
        ].join("|");
        if (bootstrapFallbackErrorKeys[fallbackKey]) {
            return;
        }
        bootstrapFallbackErrorKeys[fallbackKey] = true;
        bootstrapFallbackErrorKeyOrder.push(fallbackKey);
        if (bootstrapFallbackErrorKeyOrder.length > MAX_BOOTSTRAP_FALLBACK_ERROR_KEYS) {
            var oldestFallbackKey = bootstrapFallbackErrorKeyOrder.shift();
            if (oldestFallbackKey !== undefined) {
                delete bootstrapFallbackErrorKeys[oldestFallbackKey];
            }
        }

        var lines = ["[bootstrap] " + summary];
        if (meta && meta.stage) {
            lines.push("stage=" + meta.stage);
        }
        if (meta && meta.controller) {
            lines.push("controller=" + meta.controller);
        }
        if (fallbackMessage) {
            lines.push("message=" + sanitizeBootstrapFallbackLine(fallbackMessage));
        }
        var fallbackStack = resolveBootstrapFallbackStack(err);
        if (fallbackStack.length) {
            lines.push("stacktrace:");
            fallbackStack.forEach(function (line) {
                lines.push(line);
            });
        }
        var diagnostic = lines.join("\n");

        if (typeof window.initializeCommandBar === "function") {
            try {
                var commandBar = window.initializeCommandBar();
                if (commandBar && typeof commandBar.showResult === "function") {
                    commandBar.showResult(diagnostic);
                }
            } catch (commandBarErr) {
                console.warn("[Bootstrap] Failed to notify command bar", commandBarErr);
            }
        }
        console.error(diagnostic);
    }

    function bootstrapControllers(context) {
        var helper = window.WCControllerBootstrap || null;
        var entries = createBootstrapEntries(context);

        if (helper && typeof helper.setContext === "function") {
            helper.setContext(context);
        }

        if (helper && typeof helper.bootstrapManyBestEffort === "function") {
            helper.bootstrapManyBestEffort(entries, context, function (err, meta) {
                notifyBootstrapError(
                    "Controller bootstrap failure",
                    err,
                    { stage: "fallback", controller: meta && meta.name ? meta.name : null }
                );
            });
            return;
        }

        entries.forEach(function (entry) {
            try {
                if (helper && typeof helper.bootstrap === "function") {
                    helper.bootstrap(entry.controller, entry.name, context);
                    return;
                }
                var instance = entry.controller.getInstance();
                if (instance && typeof instance.bootstrap === "function") {
                    instance.bootstrap(context);
                }
            } catch (err) {
                notifyBootstrapError(
                    "Controller bootstrap failure",
                    err,
                    { stage: "fallback", controller: entry.name }
                );
            }
        });
    }

    function registerTocEmojiMetadata(navElement, emojiMap) {
        if (!navElement || !emojiMap) {
            return;
        }
        var anchors = navElement.querySelectorAll("a.nav-link");
        Array.prototype.forEach.call(anchors, function (anchor) {
            var href = anchor.getAttribute("href");
            if (!href) {
                return;
            }
            var emoji = emojiMap[href];
            if (!emoji) {
                return;
            }
            var existingText = (anchor.textContent || "").trim();
            var storedText = anchor.getAttribute("data-original-text");
            if (!storedText) {
                if (emoji && existingText.indexOf(emoji) === 0) {
                    existingText = existingText.slice(emoji.length).trim();
                }
                storedText = existingText;
            }
            anchor.setAttribute("data-original-text", storedText);
            anchor.setAttribute("data-toc-emoji-value", emoji);
            if (!anchor.hasAttribute("data-toc-emoji")) {
                anchor.setAttribute("data-toc-emoji", "");
            }
            if (anchor.dataset) {
                anchor.dataset.originalText = storedText;
                anchor.dataset.tocEmojiValue = emoji;
                if (typeof anchor.dataset.tocEmoji === "undefined") {
                    anchor.dataset.tocEmoji = "";
                }
            }
            anchor.textContent = storedText;
        });
    }

    function computeScrollOffset() {
        var header = document.querySelector("header .navbar");
        if (header) {
            return Math.ceil(header.getBoundingClientRect().height) + 12;
        }
        var cssOffset = parseInt(getComputedStyle(document.documentElement).getPropertyValue("--project-header-offset"), 10);
        if (Number.isNaN(cssOffset)) {
            cssOffset = 72;
        }
        return cssOffset + 12;
    }

    function scrollToSection(element) {
        if (!element) {
            return;
        }
        var offset = computeScrollOffset();
        var targetY = window.pageYOffset + element.getBoundingClientRect().top - offset;
        window.scrollTo({ top: targetY, behavior: "smooth" });
    }

    function setupTocScroll(navElement) {
        if (!navElement) {
            return;
        }
        navElement.addEventListener("click", function (event) {
            var link = event.target;
            while (link && link !== navElement) {
                if (link.tagName === "A") {
                    var hasNavLinkClass = link.classList ? link.classList.contains("nav-link") : (" " + link.className + " ").indexOf(" nav-link ") !== -1;
