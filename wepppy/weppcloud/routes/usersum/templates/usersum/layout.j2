{% extends "base_pure.htm" %}

{% block title %}{{ title or 'WEPPcloud UserSummary Documentation' }}{% endblock %}

{% block site_header %}
  {% include "usersum/header.htm" %}
{% endblock %}

{% block head_extras %}
<link rel="stylesheet" href="{{ static_url('css/markdown-theme.css') }}">
<style>
  .wc-usersum-shell {
    padding-top: 1.5rem;
    padding-bottom: 2rem;
  }

  .wc-usersum-shell .markdown-body {
    box-sizing: border-box;
    min-width: 200px;
    width: 100%;
    max-width: 980px;
    margin: 0 auto;
    padding: 45px;
  }

  @media (max-width: 767.98px) {
    .wc-usersum-shell .markdown-body {
      padding: 15px;
    }
  }
</style>
{% endblock %}

{% block body_container_class %}wc-container wc-usersum-shell{% endblock %}

{% block body %}
<article class="markdown-body">
  {% block body_content %}{% endblock %}
</article>
{% endblock %}
