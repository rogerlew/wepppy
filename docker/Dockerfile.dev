# syntax=docker/dockerfile:1
FROM python:3.12-slim AS base

# Preinstall build toolchain and native libraries required by geospatial wheels.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
        curl \
        ca-certificates \
        gnupg \
        git \
        git-lfs \
        gfortran \
        pkg-config \
        cmake \
        gdal-bin \
        libgdal-dev \
        libproj-dev \
        proj-bin \
        libgeos-dev \
        libhdf5-dev \
        libnetcdf-dev \
        libopenblas-dev \
        liblapack-dev \
        libcurl4-openssl-dev \
        libssl-dev \
        libffi-dev \
        libpq-dev \
        libxml2-dev \
        libxslt1-dev \
        libjpeg-dev \
        libpng-dev \
        libtiff-dev \
        libwebp-dev \
        libzip-dev \
        libbz2-dev \
        liblzma-dev \
        zlib1g-dev \
        aria2 \
        rsync \
        libglib2.0-0 \
        libdbus-1-3 \
        libatk1.0-0 \
        libatk-bridge2.0-0 \
        libatspi2.0-0 \
        libx11-6 \
        libxcomposite1 \
        libxdamage1 \
        libxext6 \
        libxfixes3 \
        libxrandr2 \
        libgbm1 \
        libxcb1 \
        libxkbcommon0 \
        libasound2 && \
    git lfs install --system && \
    rm -rf /var/lib/apt/lists/*

# Install Node.js 20.x (includes npm) for JS controller tests and tooling
RUN set -eux; \
    NODE_MAJOR=20; \
    mkdir -p /etc/apt/keyrings; \
    curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg; \
    echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_${NODE_MAJOR}.x nodistro main" > /etc/apt/sources.list.d/nodesource.list; \
    apt-get update && \
    apt-get install -y --no-install-recommends nodejs && \
    node --version && npm --version && \
    rm -rf /var/lib/apt/lists/*

ARG DOCKER_CLI_VERSION=26.1.4
ARG WBT_REPO=https://github.com/rogerlew/weppcloud-wbt.git
ARG WBT_REF=master
ARG WEPPPYO3_REPO=https://github.com/wepp-in-the-woods/wepppyo3.git
ARG WEPPPYO3_REF=main
RUN curl -fsSL "https://download.docker.com/linux/static/stable/x86_64/docker-${DOCKER_CLI_VERSION}.tgz" -o /tmp/docker.tgz && \
    tar -xzf /tmp/docker.tgz -C /tmp && \
    mv /tmp/docker/docker /usr/local/bin/docker && \
    chmod +x /usr/local/bin/docker && \
    rm -rf /tmp/docker /tmp/docker.tgz

ENV UV_SKIP_UPDATE_CHECK=1

# Install the uv CLI from Astral.
RUN curl -LsSf https://astral.sh/uv/install.sh | sh && \
    ln -s /root/.local/bin/uv /usr/local/bin/uv

# Resolve Python dependencies with uv inside a dedicated virtual environment.
COPY docker/requirements-uv.txt docker/requirements-stubs-uv.txt ./
RUN uv venv /opt/venv && \
    . /opt/venv/bin/activate && \
    uv pip install --requirement requirements-uv.txt && \
    GDAL_CONFIG=/usr/bin/gdal-config uv pip install \
        --no-binary fiona \
        --reinstall-package fiona \
        fiona==1.10.1 && \
    uv pip install --requirement requirements-stubs-uv.txt

# Install and load DuckDB's spatial extension using the venv's python.
RUN /opt/venv/bin/python -c "import duckdb; \
               con = duckdb.connect(); \
               con.execute('SET home_directory=\'/tmp\''); \
               con.execute('INSTALL spatial;'); \
               con.execute('LOAD spatial;'); \
               con.close()"

# Vendor wepppyo3 as a fallback so dev startup does not depend solely on bind mounts.
RUN set -eux; \
    mkdir -p /opt/vendor; \
    if git clone --depth=1 --branch "${WBT_REF}" "${WBT_REPO}" /opt/vendor/weppcloud-wbt; then \
        :; \
    else \
        git clone --depth=1 "${WBT_REPO}" /opt/vendor/weppcloud-wbt; \
        cd /opt/vendor/weppcloud-wbt; \
        git fetch --depth=1 origin "${WBT_REF}"; \
        git checkout "${WBT_REF}"; \
    fi; \
    cd /opt/vendor/weppcloud-wbt; \
    git lfs pull || true; \
    rm -rf /opt/vendor/weppcloud-wbt/.git; \
    test -f /opt/vendor/weppcloud-wbt/WBT/whitebox_tools.py; \
    if git clone --depth=1 --branch "${WEPPPYO3_REF}" "${WEPPPYO3_REPO}" /opt/vendor/wepppyo3; then \
        :; \
    else \
        git clone --depth=1 "${WEPPPYO3_REPO}" /opt/vendor/wepppyo3; \
        cd /opt/vendor/wepppyo3; \
        git fetch --depth=1 origin "${WEPPPYO3_REF}"; \
        git checkout "${WEPPPYO3_REF}"; \
    fi; \
    cd /opt/vendor/wepppyo3; \
    git lfs pull || true; \
    rm -rf /opt/vendor/wepppyo3/.git; \
    test -d /opt/vendor/wepppyo3/release/linux/py312/wepppyo3

# Mirror historical conda .pth injections so sibling repos resolve in development.
RUN SITE_PACKAGES="$(/opt/venv/bin/python -c 'import site, sys; sys.stdout.write(site.getsitepackages()[0])')" && \
    printf '/workdir/wepppy/\n' > "${SITE_PACKAGES}/wepppy.pth" && \
    printf '/workdir/wepppy/services/cao/src/\n' > "${SITE_PACKAGES}/cao.pth" && \
    printf '/workdir/weppcloud2/\n' > "${SITE_PACKAGES}/weppcloud2.pth" && \
    printf '/workdir/weppcloud-wbt/WBT/\n/opt/vendor/weppcloud-wbt/WBT/\n' > "${SITE_PACKAGES}/wbt.pth" && \
    printf '/workdir/f-esri/\n' > "${SITE_PACKAGES}/f_esri.pth" && \
    printf '/workdir/wepppyo3/release/linux/py312/\n/opt/vendor/wepppyo3/release/linux/py312/\n' > "${SITE_PACKAGES}/wepppyo3.pth"
    
# Vendor Rosetta directly from GitHub into site-packages, including LFS assets.
RUN SITE_PACKAGES="$(/opt/venv/bin/python -c 'import site, sys; sys.stdout.write(site.getsitepackages()[0])')" && \
    git clone --depth=1 https://github.com/rogerlew/rosetta /tmp/rosetta && \
    cd /tmp/rosetta && \
    git lfs pull && \
    rm -rf .git && \
    mv /tmp/rosetta "${SITE_PACKAGES}/rosetta"

# Quarto CLI for PATH-CE HTML report rendering (in-worker; ADR-0023 / D1).
# Kernelspec registration lets Quarto's jupyter engine resolve `python3`.
ARG QUARTO_VERSION=1.9.38
ARG QUARTO_SHA256=bd0d73c1042fc5f719fb87753f0874c11344e516ee2cfbe4fe3ed4e4458c3988
RUN curl -fsSL "https://github.com/quarto-dev/quarto-cli/releases/download/v${QUARTO_VERSION}/quarto-${QUARTO_VERSION}-linux-amd64.deb" -o /tmp/quarto.deb && \
    echo "${QUARTO_SHA256}  /tmp/quarto.deb" | sha256sum -c - && \
    apt-get update && \
    apt-get install -y --no-install-recommends /tmp/quarto.deb && \
    rm -f /tmp/quarto.deb && \
    rm -rf /var/lib/apt/lists/* && \
    /opt/venv/bin/python -m ipykernel install --prefix /opt/venv --name python3 && \
    quarto --version

ENV VIRTUAL_ENV=/opt/venv
ENV PATH="/opt/venv/bin:$PATH"
ENV PROJ_LIB=/usr/share/proj
ENV GDAL_DATA=/usr/share/gdal
ENV QUARTO_PYTHON=/opt/venv/bin/python

WORKDIR /workdir/wepppy

CMD ["bash"]
