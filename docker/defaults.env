# Non-secret defaults for Docker Compose + wctl.
#
# Secrets must not be placed here. Use Compose `secrets:` files under
# `docker/secrets/` and reference them via `*_FILE` environment variables.

UID=1000
GID=993

# Host mount points (adjust per host if needed).
WC1_DIR=/wc1
GEODATA_DIR=/wc1/geodata

# Dev reverse-proxy config (resolved relative to the compose file directory).
CADDY_FILE=./caddy/Caddyfile

# Public host metadata used by services/routes (non-secret).
EXTERNAL_HOST=wc.bearhive.duckdns.org
EXTERNAL_HOST_DESCRIPTION=forest.local

SITE_PREFIX=/weppcloud
